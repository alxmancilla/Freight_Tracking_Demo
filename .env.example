# MongoDB Atlas connection string (must be a replica set / Atlas cluster for transactions)
MONGODB_URI="mongodb+srv://<user>:<password>@<cluster>.mongodb.net/?retryWrites=true&w=majority"

# Database name used by all demo scripts
MONGODB_DB="freight_demo"

# Voyage AI API key (https://dash.voyageai.com)
VOYAGE_API_KEY=""

# Embedding model + dimensionality (voyage-3 = 1024 dims)
VOYAGE_MODEL="voyage-3"
VOYAGE_DIM=1024

# Generation sizing (override for smaller smoke tests)
N_SHIPMENTS=100000
N_TRACKING_EVENTS=500000
N_AGENT_MEMORY=10000
